---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} pageTitle={SITE_TITLE}>
	<section class="intro">
		<p>{SITE_DESCRIPTION}</p>
		<p class="hint">Select an article from the sidebar.</p>
	</section>
</BaseLayout>

<style>
	.intro p {
		margin: 0 0 0.75rem;
		color: var(--fg-muted);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.hint {
		color: var(--fg-subtle) !important;
		font-size: 0.8125rem !important;
	}
</style>
