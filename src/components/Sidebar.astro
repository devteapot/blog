---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const monthFormatter = new Intl.DateTimeFormat('en-US', { month: 'short' });

type MonthGroup = {
	month: number;
	label: string;
	posts: CollectionEntry<'blog'>[];
};

type YearGroup = {
	year: number;
	months: MonthGroup[];
};

const grouped: YearGroup[] = [];

for (const post of posts) {
	const date = post.data.pubDate;
	const year = date.getFullYear();
	const month = date.getMonth();

	let yearGroup = grouped.find((g) => g.year === year);
	if (!yearGroup) {
		yearGroup = { year, months: [] };
		grouped.push(yearGroup);
	}

	let monthGroup = yearGroup.months.find((m) => m.month === month);
	if (!monthGroup) {
		monthGroup = {
			month,
			label: monthFormatter.format(date),
			posts: [],
		};
		yearGroup.months.push(monthGroup);
	}

	monthGroup.posts.push(post);
}

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const icons: Record<string, string> = {
	X: `<path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>`,
	GH: `<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>`,
};

const viewBoxes: Record<string, string> = {
	X: '0 0 24 24',
	GH: '0 0 16 16',
};
---

<aside class="sidebar">
	<div class="identity">
		<a class="name" href="/">{SITE_TITLE}</a>
		<div class="social">
			{
				SOCIAL_LINKS.map((link) => (
					<a href={link.href} target="_blank" rel="noopener noreferrer">
						<span class="sr-only">{link.srOnly}</span>
						<svg
							viewBox={viewBoxes[link.label] ?? '0 0 24 24'}
							aria-hidden="true"
							width="16"
							height="16"
							set:html={icons[link.label] ?? ''}
						/>
					</a>
				))
			}
		</div>
	</div>

	<nav class="posts-nav" aria-label="Articles">
		<p class="posts-label">Articles</p>
		<div class="timeline">
			{
				grouped.map((yearGroup) => (
					<section class="year-group">
						<div class="year-row">
							<span class="year-heading">{yearGroup.year}</span>
							<span class="rail-node year-node" aria-hidden="true" />
						</div>
						{yearGroup.months.map((monthGroup) => (
							<div class="month-group">
								<ul class="post-list">
									{monthGroup.posts.map((post) => {
										const href = `/blog/${post.id}`;
										const isActive = pathname === href || pathname === `${href}/`;
										return (
											<li>
												<a href={`${href}/`} class:list={{ active: isActive }}>
													{post.data.title}
												</a>
											</li>
										);
									})}
								</ul>
								<div class="month-meta">
									<span class="month-heading">{monthGroup.label}</span>
									<span class="rail-node month-node" aria-hidden="true" />
								</div>
							</div>
						))}
					</section>
				))
			}
		</div>
	</nav>
</aside>

<style>
	.identity {
		padding: 1.5rem 1.25rem 1.25rem;
		border-bottom: var(--line);
	}

	.name {
		display: block;
		font-size: 0.9375rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--fg);
		text-decoration: none;
		line-height: 1.3;
	}

	.name:hover {
		opacity: 0.75;
		text-decoration: none;
	}

	.social {
		display: flex;
		align-items: center;
		gap: 0.15rem;
		margin-top: 0.65rem;
	}

	.social a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		color: var(--fg-muted);
		text-decoration: none;
		border-radius: var(--radius);
		transition: color 0.15s ease, background 0.15s ease;
	}

	.social a:hover {
		color: var(--fg);
		background: rgba(255, 255, 255, 0.06);
		text-decoration: none;
	}

	.posts-nav {
		/* date column + room for rail dots past the line */
		--rail-col: 2.75rem;
		--node-year: 6px;
		--node-month: 4px;
		padding: 1.25rem 0.85rem 1.5rem 1.15rem;
		flex: 1;
	}

	.posts-label {
		margin: 0 0 0.85rem;
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--fg-subtle);
	}

	.timeline {
		/* content ends at the rail; dots hang into this gutter */
		--rail-gutter: 0.5rem;
		position: relative;
		padding-right: var(--rail-gutter);
	}

	/* Single rail line at the content edge — all dots center here */
	.timeline::before {
		content: '';
		position: absolute;
		top: 0.2rem;
		bottom: 0.2rem;
		right: var(--rail-gutter);
		width: 1px;
		background: var(--border);
		pointer-events: none;
	}

	.year-group {
		margin: 0;
	}

	.year-group + .year-group {
		margin-top: 0.35rem;
	}

	.year-row {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.4rem;
		min-height: 1.25rem;
		margin: 0.7rem 0 0.35rem;
	}

	.year-group:first-child .year-row {
		margin-top: 0;
	}

	.year-heading {
		font-size: 0.6875rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		line-height: 1.2;
		text-align: right;
		color: var(--fg-muted);
	}

	.month-group {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		margin: 0 0 0.5rem;
	}

	.post-list {
		flex: 1 1 auto;
		min-width: 0;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	/*
	 * Label + dot share a flex row (aligned to each other) whose height
	 * matches one post-title row, so they sit on the same midline as the title.
	 */
	.month-meta {
		/* keep in sync with .posts-nav a font/padding below */
		--title-line: calc(0.8125rem * 1.35 + 0.28rem + 0.28rem);
		flex: 0 0 var(--rail-col);
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.35rem;
		box-sizing: border-box;
		min-height: var(--title-line);
		padding: 0;
	}

	.month-heading {
		font-size: 0.625rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		line-height: 1.2;
		text-align: right;
		text-transform: uppercase;
		color: var(--fg-subtle);
		white-space: nowrap;
	}

	/*
	 * In-flow flex item (not absolute). Sitting as the last child of a
	 * full-width-to-rail row, translateX(50%) parks the center on the line.
	 */
	.rail-node {
		display: block;
		flex: 0 0 auto;
		border-radius: 50%;
		background: var(--fg-subtle);
		box-shadow: 0 0 0 2px var(--bg);
		transform: translateX(50%);
		pointer-events: none;
	}

	.year-node {
		width: var(--node-year);
		height: var(--node-year);
		background: var(--fg-muted);
	}

	.month-node {
		width: var(--node-month);
		height: var(--node-month);
	}

	.posts-nav li {
		margin: 0;
	}

	.posts-nav a {
		display: block;
		padding: 0.28rem 0.15rem 0.28rem 0;
		font-size: 0.8125rem;
		line-height: 1.35;
		color: var(--fg-muted);
		text-decoration: none;
		border-radius: 4px;
		transition: color 0.15s ease;
	}

	.posts-nav a:hover {
		color: var(--fg);
		text-decoration: none;
	}

	.posts-nav a.active {
		color: var(--fg);
		font-weight: 500;
	}

	@media (max-width: 800px) {
		.identity {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
			padding: 1rem 1.25rem;
		}

		.social {
			margin-top: 0;
		}

		.posts-nav {
			padding: 0.85rem 1rem 1rem 1.15rem;
			--rail-col: 2.5rem;
		}

		.month-group {
			margin-bottom: 0.4rem;
		}

		.posts-nav a {
			padding: 0.25rem 0.15rem 0.25rem 0;
		}
	}
</style>
