---
const today = new Date();
---

<footer>
	<div class="inner">
		<p>&copy; {today.getFullYear()} Diego Carlino</p>
		<div class="social-links">
			<a href="https://x.com/_carlid_dev" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Follow Diego Carlino on X</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
					<path
						fill="currentColor"
						d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"
					></path>
				</svg>
			</a>
			<a href="https://github.com/devteapot" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">View Diego Carlino on GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="16" height="16">
					<path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path>
				</svg>
			</a>
		</div>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2rem 0 3rem;
	}

	.inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: var(--content-width);
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
	}

	p {
		margin: 0;
		font-size: 0.8125rem;
		color: var(--fg-subtle);
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 1.75rem;
		height: 1.75rem;
		color: var(--fg-subtle);
		text-decoration: none;
		border-radius: var(--radius);
		transition: color 0.15s ease;
	}

	.social-links a:hover {
		color: var(--fg);
		text-decoration: none;
	}
</style>
