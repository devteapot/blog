---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import {
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_TITLE,
	SOCIAL_LINKS,
} from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	pageType?: 'website' | 'article';
	pubDate?: Date;
	updatedDate?: Date;
	tags?: string[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	pageType = 'website',
	pubDate,
	updatedDate,
	tags = [],
} = Astro.props;

const siteURL = new URL('/', Astro.site);
const imageURL = new URL(image.src, Astro.site);
const author = {
	'@type': 'Person',
	'@id': new URL('/#person', Astro.site).href,
	name: SITE_AUTHOR,
	url: siteURL.href,
	sameAs: SOCIAL_LINKS.map(({ href }) => href),
};

const structuredData =
	pageType === 'article'
		? {
				'@context': 'https://schema.org',
				'@type': 'BlogPosting',
				'@id': `${canonicalURL.href}#article`,
				headline: title,
				description,
				url: canonicalURL.href,
				mainEntityOfPage: canonicalURL.href,
				image: imageURL.href,
				datePublished: pubDate?.toISOString(),
				dateModified: (updatedDate ?? pubDate)?.toISOString(),
				author,
				publisher: author,
				keywords: tags.length > 0 ? tags : undefined,
				inLanguage: 'en',
			}
		: {
				'@context': 'https://schema.org',
				'@type': 'WebSite',
				'@id': `${siteURL.href}#website`,
				name: SITE_TITLE,
				description: SITE_DESCRIPTION,
				url: siteURL.href,
				author,
				inLanguage: 'en',
			};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="dark" />
<meta name="theme-color" content="#000000" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('/rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-geist-sans" preload />
<Font cssVariable="--font-geist-mono" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
{
	pageType === 'article' && (
		<>
			<meta property="article:author" content={SITE_AUTHOR} />
			{pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
			{updatedDate && (
				<meta property="article:modified_time" content={updatedDate.toISOString()} />
			)}
			{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		</>
	)
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
